{
  "name": "staks-flow",
  "version": "1.0.0",
  "description": "STAKS FLOW — Modern Task Management App",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "nodemon --watch . --ext js,json server.js",
    "prod": "NODE_ENV=production pm2 start ecosystem.config.js --env production",
    "prod:stop": "pm2 stop staks-flow",
    "prod:reload": "pm2 reload staks-flow --update-env",
    "prod:logs": "pm2 logs staks-flow",
    "prod:status": "pm2 status",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.18.0",
    "prisma": "^5.22.0",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
