# ╔══════════════════════════════════════════════════════════════════╗
# ║         STAKS FLOW — Production Environment Variables           ║
# ║  Copy this file to .env and fill in your actual values          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (PostgreSQL — recommended for production) ────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://staksflow_user:YOUR_STRONG_PASSWORD@localhost:5432/staksflow_db"

# For SQLite (dev only — NOT recommended for production):
# DATABASE_URL="file:./database/staksflow.db"

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARACTERS
JWT_EXPIRES=7d

# ── Admin Setup ──────────────────────────────────────────────────────────────
# Used to promote the first admin via POST /api/auth/promote-first-admin
# Set a strong secret and remove/disable this endpoint after setup!
ADMIN_SETUP_SECRET=CHANGE_THIS_TO_YOUR_ADMIN_SETUP_SECRET

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Rate Limiting (optional overrides) ───────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200
