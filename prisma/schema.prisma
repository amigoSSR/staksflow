generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  username           String               @unique
  email              String               @unique
  password           String
  role               String               @default("user")
  created_at         DateTime             @default(now())
  activities         ActivityLog[]
  diaries            Diary[]
  dutySchedules      DutySchedule[]
  houseRules         HouseRule[]
  manualBooks        ManualBook[]
  projectDiaries     ProjectDiary[]
  projectMembers     ProjectMember[]
  assignedMilestones RoadmapMilestone[]
  roadmapLogs        RoadmapProgressLog[]
  schedules          Schedule[]
  weeklyReports      WeeklyReport[]

  @@map("users")
}

model Diary {
  id                   String    @id @default(uuid())
  title                String
  activity_description String
  project_event        String
  category             String
  date                 String
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  created_by           String
  schedule_id          String?
  creator              User      @relation(fields: [created_by], references: [id], onDelete: Cascade)
  schedule             Schedule? @relation(fields: [schedule_id], references: [id])

  @@map("diaries")
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  diary_title String?
  category    String?
  timestamp   DateTime @default(now())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model HouseRule {
  id         String   @id @default(uuid())
  title      String
  content    String
  created_by String
  created_at DateTime @default(now())
  creator    User     @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("house_rules")
}

model DutySchedule {
  id          String @id @default(uuid())
  day         String
  member_name String
  created_by  String
  creator     User   @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("duty_schedules")
}

model Schedule {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  start_date  String
  end_date    String
  created_by  String
  created_at  DateTime @default(now())
  diaries     Diary[]
  creator     User     @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model ScheduleCategory {
  id         String   @id @default(uuid())
  name       String   @unique
  color      String   @default("blue")
  created_at DateTime @default(now())

  @@map("schedule_categories")
}

model Project {
  id             String          @id @default(uuid())
  project_name   String
  description    String?
  start_date     String
  project_status String          @default("ongoing")
  completed_at   DateTime?
  completed_by   String?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  diaries        ProjectDiary[]
  members        ProjectMember[]
  roadmap        ProjectRoadmap?
  weeklyReports  WeeklyReport[]

  @@map("projects")
}

model ProjectMember {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  role       String
  created_at DateTime @default(now())
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("project_members")
}

model ProjectDiary {
  id                   String   @id @default(uuid())
  project_id           String?
  diary_title          String
  activity_description String
  work_progress        Int
  created_by           String
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  creator              User     @relation(fields: [created_by], references: [id], onDelete: Cascade)
  project              Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_diaries")
}

model WeeklyReport {
  id            String   @id @default(uuid())
  project_id    String
  user_id       String
  report_name   String
  report_period String
  file_path     String
  generated_at  DateTime @default(now())
  project       Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("weekly_reports")
}

model CombinedWeeklyReport {
  id               String   @id @default(uuid())
  report_name      String
  report_period    String   @unique
  file_name        String
  file_path        String
  generated_at     DateTime @default(now())
  leader_count     Int      @default(0)
  diary_count      Int      @default(0)
  total_activities Int      @default(0)

  @@map("combined_weekly_reports")
}

model ManualCategory {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  order       Int          @default(0)
  icon        String       @default("bi-journal-text")
  access_role String       @default("user")
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  manuals     ManualBook[]

  @@map("manual_categories")
}

model ManualBook {
  id          String         @id @default(uuid())
  category_id String
  title       String
  content     String
  order       Int            @default(0)
  access_role String         @default("user")
  created_by  String
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  category    ManualCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  creator     User           @relation(fields: [created_by], references: [id])

  @@map("manual_books")
}

model ProjectRoadmap {
  id                  String               @id @default(uuid())
  project_id          String               @unique
  roadmap_title       String
  description         String?
  start_date          String
  deadline            String
  progress_percentage Int                  @default(0)
  status              String               @default("planned")
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  project             Project              @relation(fields: [project_id], references: [id], onDelete: Cascade)
  milestones          RoadmapMilestone[]
  logs                RoadmapProgressLog[]

  @@map("project_roadmaps")
}

model RoadmapMilestone {
  id                  String               @id @default(uuid())
  roadmap_id          String
  assigned_to         String?
  title               String
  description         String?
  start_date          String?
  deadline            String?
  progress_percentage Int                  @default(0)
  status              String               @default("pending")
  activity_note       String?
  order               Int                  @default(0)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  assignee            User?                @relation(fields: [assigned_to], references: [id])
  roadmap             ProjectRoadmap       @relation(fields: [roadmap_id], references: [id], onDelete: Cascade)
  logs                RoadmapProgressLog[]

  @@map("roadmap_milestones")
}

model RoadmapProgressLog {
  id           String            @id @default(uuid())
  roadmap_id   String
  milestone_id String?
  user_id      String
  action       String
  details      String?
  timestamp    DateTime          @default(now())
  milestone    RoadmapMilestone? @relation(fields: [milestone_id], references: [id])
  roadmap      ProjectRoadmap    @relation(fields: [roadmap_id], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("roadmap_progress_logs")
}
